{
  "name": "ab-washing-worker",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create ab-washing-db",
    "db:execute": "wrangler d1 execute ab-washing-db --file=./schema.sql",
    "db:execute:prod": "wrangler d1 execute ab-washing-db --env production --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
